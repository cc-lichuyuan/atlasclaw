# AtlasClaw Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider Configuration - Doubao
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=your-doubao-api-key-here

# LLM Provider Configuration - DeepSeek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Jira Configuration
JIRA_USERNAME=admin
JIRA_PASSWORD=your-jira-password-here
JIRA_TOKEN=your-jira-token-here

# CloudChef SmartCMP Agent SK
ATLASCLAW_WEBHOOK_SK_SMARTCMP_PREAPPROVAL=sk-for-smartcmp-preapproval-token

# OIDC / Keycloak SSO
OIDC_ISSUER=http://<keycloak-host>:<port>/realms/<realm>
OIDC_CLIENT_ID=atlasclaw
OIDC_CLIENT_SECRET=your-oidc-client-secret-here
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ========================================
# SmartCMP Provider Configuration
# ========================================
# Choose ONE of the following modes:

# --- Mode 1: SaaS Environment Test UserName (Auto-Login) ---
# CMP_URL=https://console.smartcmp.cloud
# CMP_USERNAME=Agent@cloudchef.io
# CMP_PASSWORD=d41e98d1eafa6d6011d3a70f1a5b92f0
# CMP_AUTH_URL=https://account.smartcmp.cloud/bss-api/api/authentication

# --- Mode 2: Private Deployment (Auto-Login) ---
# CMP_URL=https://your-cmp-server-ip
# CMP_USERNAME=your_username
# CMP_PASSWORD=your_password_md5_hash
# CMP_AUTH_URL=https://your-cmp-server-ip/platform-api/login

# --- Mode 3: Direct Cookie (Any Environment) ---
# CMP_URL=https://your-cmp-server
# CMP_COOKIE=CloudChef-Authenticate=xxx; tenant_id=xxx; ...
